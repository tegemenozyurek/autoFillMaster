{
  "manifest_version": 3,
  "name": "AutoFillMaster",
  "version": "1.0.0",
  "description": "Type text naturally into any input, textarea, or contenteditable field on any webpage.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "AutoFillMaster"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils.js", "typingEngine.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["utils.js", "typingEngine.js", "icons/penCursor.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
